{
  "expo": {
    "name": "RouteO",
    "slug": "RouteO",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "routeo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "buildNumber": "2",
      "bundleIdentifier": "com.eddie.routeo",
      "appleTeamId": "9556L24Y4A",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.routeo.app"
        ]
      },
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        },
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "RouteO lets you attach a photo when submitting a community deal.",
        "NSCameraUsageDescription": "RouteO lets you take a photo when submitting a community deal."
      }
    },
    "android": {
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.CAMERA"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "versionCode": 2,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.eddie.routeo"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "react-native-maps",
        {
          "googleMapsApiKey": "AIzaSyCKwAVVCbxHKsKViJ4Dq0ZQ5r6k-arue3E"
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0C0E12"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#00A78D"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "RouteO needs your location to show nearby stops and transit options."
        }
      ],
      "expo-image-picker",
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": true
          }
        }
      ],
      "@bacons/apple-targets",
      [
        "@sentry/react-native/expo",
        {
          "organization": "routeo",
          "project": "react-native"
        }
      ],
      "@sentry/react-native",
      "expo-speech-recognition"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b9dfd92e-5a92-49d3-a1aa-20220009ebd5"
      }
    }
  }
}
